<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Тёмная Сторона Любви</title>
    <style>
        body { 
            background: #000; color: #fff; font-family: 'Arial', sans-serif; 
            text-align: center; margin: 0; padding: 20px;
        }
        .container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 90vh; }
        h1 { color: #ff0055; text-shadow: 0 0 10px #ff0055; }
        
        #display-area { min-height: 200px; margin: 20px 0; width: 100%; }
        .action-text { font-size: 1.5rem; font-weight: bold; margin-bottom: 15px; color: #ffcccc; }
        .gif-placeholder { width: 100%; max-width: 300px; border-radius: 10px; border: 2px solid #ff0055; }
        
        #timer { font-size: 3rem; color: #ff0055; margin: 10px 0; display: none; }

        button {
            background: #ff0055; border: none; padding: 15px 30px; 
            color: white; font-size: 1.2rem; border-radius: 50px;
            cursor: pointer; box-shadow: 0 0 15px #ff0055; transition: 0.3s;
        }
        button:active { transform: scale(0.9); box-shadow: 0 0 5px #ff0055; }
        
        .role-selector { margin-bottom: 20px; }
        select { background: #222; color: #fff; padding: 10px; border: 1px solid #ff0055; border-radius: 5px; }
    </style>
</head>
<body>

<div class="container">
    <h1>Тёмная Сторона 😈</h1>

    <div class="role-selector">
        <label>Кто делает? </label>
        <select id="role">
            <option value="Он">Он</option>
            <option value="Она">Она</option>
            <option value="Рандом">Рандом</option>
        </select>
    </div>

    <div id="display-area">
        <div id="action" class="action-text">Готовы к грязи?</div>
        <div id="timer">60</div>
        <img id="gif" class="gif-placeholder" src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJtZzR6bm94bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/3o7TKMGpxxcaatOAHm/giphy.gif" style="display:none;">
    </div>

    <button onclick="startDirtyGame()">ХОЧУ ГРЯЗЬ 🔞</button>
</div>

<script>
    const actions = [
        "Сделать массаж с маслом",
        "Шлепнуть партнера 5 раз",
        "Поцеловать в самое горячее место",
        "Исполнить любое желание на 5 минут",
        "Снять одну деталь одежды зубами"
    ];

    const gifs = [
        "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJtZzR6bm94bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/l2SpMUEMCHXKdfpT2/giphy.gif",
        "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJtZzR6bm94bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6bmZ6JmVwPXYxX2ludGVybmFsX2dpZl9ieV9pZCZjdD1n/3o7TKVUn7iM8FMEU24/giphy.gif"
    ];

    let timerInterval;

    function startDirtyGame() {
        clearInterval(timerInterval);
        
        // 1. Выбор роли
        let role = document.getElementById('role').value;
        if(role === 'Рандом') {
            role = Math.random() > 0.5 ? 'Он' : 'Она';
        }

        // 2. Рандомное действие
        const randomAction = actions[Math.floor(Math.random() * actions.length)];
        const randomGif = gifs[Math.floor(Math.random() * gifs.length)];

        document.getElementById('action').innerText = `${role}: ${randomAction}`;
        
        // 3. Показ гифки
        const gifEl = document.getElementById('gif');
        gifEl.src = randomGif;
        gifEl.style.display = 'block';

        // 4. Таймер на 60 секунд
        let timeLeft = 60;
        const timerEl = document.getElementById('timer');
        timerEl.style.display = 'block';
        timerEl.innerText = timeLeft;

        timerInterval = setInterval(() => {
            timeLeft--;
            timerEl.innerText = timeLeft;
            if (timeLeft <= 0) {
                clearInterval(timerInterval);
                timerEl.innerText = "ВРЕМЯ ВЫШЛО!";
            }
        }, 1000);
    }
</script>

</body>
</html>
